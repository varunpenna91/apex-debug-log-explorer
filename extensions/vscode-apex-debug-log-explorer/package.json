{
  "name": "apex-debug-log-explorer",
  "displayName": "Apex Debug Log Explorer",
  "description": "Explore Salesforce Apex debug logs with a local graph for Apex, triggers, Flow, DML, SOQL, async, callouts, email, and errors.",
  "version": "0.1.10",
  "publisher": "penna-vibe-code-apps",
  "icon": "media/icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Visualization",
    "Debuggers",
    "Other"
  ],
  "keywords": [
    "salesforce",
    "apex",
    "debug log",
    "debug logs",
    "apex logs",
    "apex debug",
    "soql",
    "dml",
    "flow",
    "trigger",
    "governor limits",
    "salesforce logs"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/varunpenna91/apex-debug-log-explorer.git"
  },
  "homepage": "https://github.com/varunpenna91/apex-debug-log-explorer",
  "bugs": {
    "url": "https://github.com/varunpenna91/apex-debug-log-explorer/issues"
  },
  "activationEvents": [
    "onCommand:apexDebugLogExplorer.openLog",
    "onCommand:apexDebugLogExplorer.openCurrentFile"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "apexDebugLogExplorer.openLog",
        "title": "Apex Debug Log Explorer: Open Log"
      },
      {
        "command": "apexDebugLogExplorer.openCurrentFile",
        "title": "Open with Apex Debug Log Explorer"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "apexDebugLogExplorer.openCurrentFile",
          "when": "resourceExtname == .log || resourceExtname == .txt",
          "group": "navigation@50"
        }
      ],
      "explorer/context": [
        {
          "command": "apexDebugLogExplorer.openCurrentFile",
          "when": "resourceExtname == .log || resourceExtname == .txt",
          "group": "navigation@50"
        }
      ],
      "editor/title/context": [
        {
          "command": "apexDebugLogExplorer.openCurrentFile",
          "when": "resourceExtname == .log || resourceExtname == .txt",
          "group": "navigation@50"
        }
      ]
    }
  },
  "files": [
    "dist",
    "webview-dist",
    "media",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ]
}
