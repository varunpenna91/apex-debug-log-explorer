{
  "name": "apex-debug-log-explorer",
  "private": true,
  "version": "0.1.9",
  "description": "Local-first interactive Salesforce Apex debug log explorer for transaction graphs, DML, SOQL, Flow, async, email, callout, and error analysis.",
  "author": "Apex Debug Log Explorer contributors",
  "license": "MIT",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "typecheck": "tsc",
    "build": "npm run typecheck && vite build",
    "desktop": "npm run build && electron .",
    "preview": "vite preview --host 127.0.0.1",
    "package:mac": "npm run build && electron-builder --mac dmg --publish never",
    "package:mac:x64": "npm run build && electron-builder --mac dmg --x64 --publish never",
    "package:mac:arm64": "npm run build && electron-builder --mac dmg --arm64 --publish never",
    "package:win": "npm run build && electron-builder --win nsis --publish never",
    "package:win:x64": "npm run build && electron-builder --win nsis --x64 --publish never",
    "package:linux": "npm run build && electron-builder --linux --publish never",
    "package:desktop": "npm run build && electron-builder --publish never",
    "security:audit": "npm audit --audit-level=moderate && npm audit signatures",
    "vscode:compile": "tsc -p extensions/vscode-apex-debug-log-explorer/tsconfig.json",
    "vscode:prepare": "npm run build && node scripts/prepare-vscode-extension.mjs && npm run vscode:compile",
    "vscode:package": "npm run vscode:prepare && node scripts/package-vscode-extension.mjs",
    "vscode:marketplace-url": "node scripts/print-vscode-marketplace-url.mjs",
    "vscode:publish": "npm run vscode:package && node scripts/publish-vscode-extension.mjs"
  },
  "build": {
    "appId": "com.apexdebuglogexplorer.app",
    "productName": "Apex Debug Log Explorer",
    "artifactName": "apex-debug-log-explorer-${version}-${os}-${arch}.${ext}",
    "icon": "build/icon.png",
    "directories": {
      "output": "release/desktop"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        "dmg"
      ],
      "identity": "-"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Apex Debug Log Explorer"
    },
    "linux": {
      "category": "Development",
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "tar.gz"
      ]
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.120.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vscode/vsce": "^3.9.1",
    "@xyflow/react": "^12.10.0",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.554.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  }
}
